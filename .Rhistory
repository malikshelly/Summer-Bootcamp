script_file <- gsub("~\\+~", " ", sub("^--file=", "", commandArgs(FALSE)[grep("^--file=", commandArgs(FALSE))][1]))
script_dir <- dirname(normalizePath(script_file))
setwd(script_dir)
load_frey <- function() as.matrix(read.csv("frey_faces_samples.csv", check.names = FALSE))
plot_frey_sample <- function(x) {
image(1:20, 1:28, t(matrix(x, 28, 20, byrow = TRUE))[, 28:1],
col = gray.colors(256, start = 1, end = 0), axes = FALSE, useRaster = TRUE)
}
# Return PCA coordinates, reconstructions, component rows, eigenvalues, and mean.
pca_encode_decode <- function(X, k) {
fit <- prcomp(X, center = TRUE, scale. = FALSE, rank. = k)
Z <- fit$x[, seq_len(k), drop = FALSE]
V <- t(fit$rotation[, seq_len(k), drop = FALSE])
mu <- fit$center
Xt <- Z %*% V + matrix(mu, nrow(X), ncol(X), byrow = TRUE)
list(Z = Z, Xt = Xt, V = V, eigenvalues = fit$sdev[seq_len(k)]^2, mu = mu)
}
X <- load_frey()
